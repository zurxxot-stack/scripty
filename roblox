local orbitPredictionEnabled = false
local orbitPredictionStrength = 0.2
local orbitAutoPrediction = true
local PRED_WINDOW = 8
local PRED_TP_DIST = 80
local PRED_JERK_MAX = 2000
local PRED_DECAY = 0.75
local predBuf = {}
for i = 1, PRED_WINDOW do predBuf[i] = { px=0, py=0, pz=0, t=0 } end
local predBufN, predBufHead = 0, 0
local kPx,kPy,kPz = 0,0,0
local kVx,kVy,kVz = 0,0,0
local kAx,kAy,kAz = 0,0,0
local kReady, predConf = false, 0
local function predReset()
    predBufN, predBufHead = 0, 0
    kPx,kPy,kPz = 0,0,0
    kVx,kVy,kVz = 0,0,0
    kAx,kAy,kAz = 0,0,0
    kReady, predConf = false, 0
end
local function predFitWindow()
    local n = predBufN
    if n < 2 then return end
    local head = predBufHead
    local tn = predBuf[head].t
    local sw0,sw1,sw2,sw3,sw4 = 0,0,0,0,0
    local srpx,srpy,srpz = 0,0,0
    local srspx,srspy,srspz = 0,0,0
    local srs2px,srs2py,srs2pz = 0,0,0
    local w = 1.0
    for i = 0, n-1 do
        local slot = predBuf[((head - 1 - i) % PRED_WINDOW) + 1]
        local s = slot.t - tn
        local s2 = s * s
        sw0 += w; sw1 += w*s; sw2 += w*s2
        sw3 += w*s2*s; sw4 += w*s2*s2
        local wpx,wpy,wpz = w*slot.px, w*slot.py, w*slot.pz
        srpx  += wpx;    srpy  += wpy;    srpz  += wpz
        srspx += wpx*s;  srspy += wpy*s;  srspz += wpz*s
        srs2px+= wpx*s2; srs2py+= wpy*s2; srs2pz+= wpz*s2
        w *= PRED_DECAY
    end
    local c00 = sw2*sw4 - sw3*sw3
    local c01 = sw3*sw2 - sw1*sw4
    local c02 = sw1*sw3 - sw2*sw2
    local det = sw0*c00 + sw1*c01 + sw2*c02
    if math.abs(det) < 1e-9 then return end
    local inv = 1 / det
    local c10 = sw3*sw2 - sw1*sw4
    local c11 = sw0*sw4 - sw2*sw2
    local c12 = sw1*sw2 - sw0*sw3
    local c20 = sw1*sw3 - sw2*sw2
    local c21 = sw2*sw1 - sw0*sw3
    local c22 = sw0*sw2 - sw1*sw1
    local function solveVelAccel(b0, b1, b2)
        return (b0*c10 + b1*c11 + b2*c12) * inv,
               (b0*c20 + b1*c21 + b2*c22) * inv * 2
    end
    local fvx,fax = solveVelAccel(srpx, srspx, srs2px)
    local fvy,fay = solveVelAccel(srpy, srspy, srs2py)
    local fvz,faz = solveVelAccel(srpz, srspz, srs2pz)
    local jdx,jdy,jdz = fax-kAx, fay-kAy, faz-kAz
    local dtSample = math.max(n >= 2 and (tn - predBuf[((head-2)%PRED_WINDOW)+1].t) or 1, 1e-4)
    local jerk = math.sqrt(jdx*jdx + jdy*jdy + jdz*jdz) / dtSample
    if jerk > PRED_JERK_MAX then predConf = math.max(predConf - 0.4, 0) end
    local trust = math.clamp(n / PRED_WINDOW, 0.2, 1.0)
    local tv, ta = trust * 0.6, trust * 0.3
    kVx += (fvx-kVx)*tv; kVy += (fvy-kVy)*tv; kVz += (fvz-kVz)*tv
    kAx += (fax-kAx)*ta; kAy += (fay-kAy)*ta; kAz += (faz-kAz)*ta
    kPx = predBuf[head].px; kPy = predBuf[head].py; kPz = predBuf[head].pz
    kReady = true
    predConf = math.min(predConf + 0.15, 1.0)
end
local function predUpdate(pos)
    local now = tick()
    local px,py,pz = pos.X, pos.Y, pos.Z
    if predBufN > 0 then
        local s = predBuf[predBufHead]
        local dx,dy,dz = px-s.px, py-s.py, pz-s.pz
        if dx*dx + dy*dy + dz*dz > PRED_TP_DIST*PRED_TP_DIST then predReset() end
    end
    predBufHead = (predBufHead % PRED_WINDOW) + 1
    local slot = predBuf[predBufHead]
    slot.px, slot.py, slot.pz, slot.t = px, py, pz, now
    predBufN = math.min(predBufN + 1, PRED_WINDOW)
    predFitWindow()
end
local function predExtrapolate(ahead)
    if not kReady then return Vector3.new(kPx,kPy,kPz) end
    local c = predConf
    local ac = math.max(1 - ahead * 1.2, 0) * c
    local h2 = 0.5 * ahead * ahead
    return Vector3.new(
        kPx + kVx*ahead*c + kAx*h2*ac,
        kPy + kVy*ahead*c + kAy*h2*ac,
        kPz + kVz*ahead*c + kAz*h2*ac
    )
end
local function predLookAhead()
    if not orbitAutoPrediction then return orbitPredictionStrength end
    local spd = math.sqrt(kVx*kVx + kVy*kVy + kVz*kVz)
    local acc = math.sqrt(kAx*kAx + kAy*kAy + kAz*kAz)
    return math.clamp((math.clamp(spd/300,0,1) + math.clamp(acc/400,0,0.4)) * predConf, 0, 1.4)
end
