local function teleportAttackBypass(targets)
    pcall(function()
        if not targets or #targets == 0 or not humanoidRootPart then return end
        local allTargets = {}
        local primaryTarget = nil
        local primaryHRP = nil
        for _, targetChar in pairs(targets) do
            local head = targetChar:FindFirstChild("Head")
            local hrp = targetChar:FindFirstChild("HumanoidRootPart")
            if head and hrp then
                table.insert(allTargets, {targetChar, head})
                if not primaryTarget then primaryTarget = head primaryHRP = hrp end
            end
        end
        if #allTargets == 0 or not primaryHRP then return end
        local originalCFrame = humanoidRootPart.CFrame
        local originalTargetCFrame = nil
        if BringMobsEnabled then
            pcall(function() primaryHRP:SetNetworkOwner(player) end)
            local bringPos = humanoidRootPart.Position + Vector3.new(0, 5, 0)
            originalTargetCFrame = primaryHRP.CFrame
            primaryHRP.CFrame = CFrame.new(bringPos)
            primaryHRP.Velocity = Vector3.new(0, 0, 0)
            primaryHRP.CanCollide = false
            humanoidRootPart.CFrame = CFrame.new(bringPos + Vector3.new(0, -3, 0))
        else
            originalTargetCFrame = primaryHRP.CFrame
            humanoidRootPart.CFrame = CFrame.new(primaryHRP.Position + Vector3.new(0, 3, 0))
        end
        task.wait(0.01)
        RegisterAttack:FireServer(0)
        RegisterHit:FireServer(primaryTarget, allTargets)
        task.wait(0.02)
        humanoidRootPart.CFrame = originalCFrame
        if BringMobsEnabled and originalTargetCFrame then
            pcall(function() if primaryHRP and primaryHRP.Parent then primaryHRP.CFrame = originalTargetCFrame end end)
        end
    end)
end

