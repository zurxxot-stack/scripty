local hTeleportSaved = nil
local hUnhittableConn = nil

local function setUnhittable(enabled)
    if hUnhittableConn then hUnhittableConn:Disconnect() hUnhittableConn = nil end
    if enabled then
        hUnhittableConn = RunService.Stepped:Connect(function()
            local char = player.Character
            if not char then return end
            for _, p in char:GetDescendants() do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                    p.CanTouch   = false
                    p.CanQuery   = false
                end
            end
        end)
    else
        local char = player.Character
        if char then
            for _, p in char:GetDescendants() do
                if p:IsA("BasePart") then
                    p.CanCollide = true
                    p.CanTouch   = true
                    p.CanQuery   = true
                end
            end
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.N then toggleTeleportToSky() end
    if input.KeyCode == Enum.KeyCode.H then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        if hTeleportSaved then
            hrp.CFrame = hTeleportSaved
            hTeleportSaved = nil
            setUnhittable(false)
        else
            hTeleportSaved = hrp.CFrame
            hrp.CFrame = CFrame.new(0, 10000000, 0)
            setUnhittable(true)
        end
    end
end)

