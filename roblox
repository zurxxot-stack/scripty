    stopFly()
    stopAutoV4()
    stopESP()
    stopAntiMover()
    stopUnbreakable()
    bToggled = false
    local char = player.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then local flag = hrp:FindFirstChild("BUpLoop") if flag then flag:Destroy() end end
    end
    if orbitConnection then orbitConnection:Disconnect() end
    if instantTPConnection then instantTPConnection:Disconnect() end
    if FastAttackConnection then FastAttackConnection:Disconnect() end
    if SpeedConnection then SpeedConnection:Disconnect() end
    if AutoTPConnection then AutoTPConnection:Disconnect() end
    for _, c in DeathBarrierConnections do if c and c.Disconnect then c:Disconnect() end end
    if HitboxEnabled then extendHitboxes(false) end
    if DeathBarrierDisabled then toggleDeathBarrier(false) end
    if autoResetThread then task.cancel(autoResetThread) autoResetThread = nil end
    if testScriptEnabled then stopTestScript() end
end)
