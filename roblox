local EXTRA_DIR  = vector.create(-0.9945698976516724, 0, 0.10407081246376038)
local DIR_A = vector.create(1, 0, 0)
local DIR_B = vector.create(-1, 0, 0)
local DIRS_360 = {}
do
    local scales = {1, 100, 9999}
    for _, scale in ipairs(scales) do
        for i = 0, 7 do
            local a = (i / 8) * math.pi * 2
            table.insert(DIRS_360, vector.create(math.cos(a) * scale, 0, math.sin(a) * scale))
        end
    end
end
local DIRS_360_COUNT = #DIRS_360
local function findRemote(toolName)
    local char = player.Character
    if char then
        local t = char:FindFirstChild(toolName)
        if t then local r = t:FindFirstChild("LeftClickRemote") if r then return r end end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        local t = bp:FindFirstChild(toolName)
        if t then return t:FindFirstChild("LeftClickRemote") end
    end
end
local function makeSingleAura(toolName)
    local state = { enabled = false, conn = nil, remote = nil, remoteSkip = 0, frame = 0 }
    function state.start()
        if state.conn then state.conn:Disconnect() end
        state.remote, state.remoteSkip, state.frame = nil, 0, 0
        state.conn = RunService.Heartbeat:Connect(function()
            if not state.enabled then state.conn:Disconnect() state.conn = nil return end
            state.frame += 1
            if state.frame % 6 ~= 0 then return end
            state.remoteSkip += 1
            if state.remoteSkip >= 20 or not state.remote then
                state.remoteSkip = 0
                state.remote = findRemote(toolName)
            end
            local r = state.remote
            if not r then return end
            local fs = r.FireServer
            pcall(function()
                fs(r, SINGLE_DIR, 1)
                fs(r, DIR_A, 1)
                fs(r, DIR_B, 1)
                fs(r, EXTRA_DIR, 2)
            end)
        end)
    end
    function state.stop()
        state.enabled = false
        if state.conn then state.conn:Disconnect() state.conn = nil end
        state.remote = nil
    end
    return state
end
local function makeMultiAura(toolName)
    local state = { enabled = false, conn = nil, remoteSkip = 0, remote = nil, frame = 0, dirIndex = 0 }
    function state.start()
        if state.conn then state.conn:Disconnect() end
        state.remoteSkip, state.remote, state.frame, state.dirIndex = 0, nil, 0, 0
        state.conn = RunService.Heartbeat:Connect(function()
            if not state.enabled then state.conn:Disconnect() state.conn = nil return end
            state.frame += 1
            if state.frame % 6 ~= 0 then return end
            state.remoteSkip += 1
            if state.remoteSkip >= 20 or not state.remote then
                state.remoteSkip = 0
                state.remote = findRemote(toolName)
            end
            local r = state.remote
            if not r then return end
            local fs = r.FireServer
            pcall(function()
                for _ = 1, 8 do
                    state.dirIndex = (state.dirIndex % DIRS_360_COUNT) + 1
                    fs(r, DIRS_360[state.dirIndex], 1)
                end
            end)
        end)
    end
    function state.stop()
        state.enabled = false
        if state.conn then state.conn:Disconnect() state.conn = nil end
        state.remote = nil
    end
    return state
end
