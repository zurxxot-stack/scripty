-- ════════════════════════════════════════════════
-- SHARED AURA DIRECTIONS
-- ════════════════════════════════════════════════
local allDirs = {}
do
    local count, scales = 16, {1, 100, 9999}
    for _, scale in ipairs(scales) do
        for i = 0, count - 1 do
            local yaw = (i / count) * math.pi * 2
            local pitch = math.sin((i / count) * math.pi) * math.pi / 2
            table.insert(allDirs, vector.create(
                math.cos(pitch) * math.cos(yaw) * scale,
                math.sin(pitch) * scale,
                math.cos(pitch) * math.sin(yaw) * scale
            ))
        end
    end
end
local dirCount = #allDirs
local EXTRA_DIR = vector.create(-0.9945698976516724, 0, 0.10407081246376038)
local SINGLE_DIR = vector.create(0.12935088574886322, 0, -0.9915988445281982)

-- ════════════════════════════════════════════════
-- GENERIC AURA FACTORY
-- ════════════════════════════════════════════════
local function findRemote(toolName)
    local lp = Players.LocalPlayer
    local function search(parent)
        local tool = parent and parent:FindFirstChild(toolName)
        return tool and tool:FindFirstChild("LeftClickRemote")
    end
    return search(lp.Character) or search(lp:FindFirstChild("Backpack"))
end

local function makeSingleAura(toolName)
    local state = { enabled = false, conn = nil }
    function state.start()
        if state.conn then state.conn:Disconnect() end
        state.conn = RunService.Heartbeat:Connect(function()
            if not state.enabled then state.conn:Disconnect() state.conn = nil return end
            local remote = findRemote(toolName)
            if remote then pcall(remote.FireServer, remote, SINGLE_DIR, 1) end
        end)
    end
    function state.stop()
        state.enabled = false
        if state.conn then state.conn:Disconnect() state.conn = nil end
    end
    return state
end

-- All active multi auras share one Heartbeat connection and one direction index
-- so total FireServer calls = (number of enabled auras) × 1 per frame, not × 26
local activeMultiAuras = {}
local multiSharedConn = nil
local multiFrame = 0
local multiDirIdx = 0
local MULTI_THROTTLE = 2  -- fire every N frames

local function multiSharedTick()
    multiFrame += 1
    if multiFrame % MULTI_THROTTLE ~= 0 then return end
    for _, state in activeMultiAuras do
        if state.enabled then
            if not state.remote or state.remoteSkip >= 120 then
                state.remote = findRemote(state.toolName)
                state.remoteSkip = 0
            else
                state.remoteSkip += 1
            end
            if state.remote then
                pcall(function()
                    for _ = 1, 4 do
                        multiDirIdx = (multiDirIdx % dirCount) + 1
                        state.remote:FireServer(allDirs[multiDirIdx], 1)
                    end
                    state.remote:FireServer(EXTRA_DIR, 2)
                    state.remote:FireServer(EXTRA_DIR, 2)
                end)
            end
        end
    end
end

local function refreshMultiConn()
    local anyActive = false
    for _, state in activeMultiAuras do
        if state.enabled then anyActive = true break end
    end
    if anyActive and not multiSharedConn then
        multiSharedConn = RunService.Heartbeat:Connect(multiSharedTick)
    elseif not anyActive and multiSharedConn then
        multiSharedConn:Disconnect()
        multiSharedConn = nil
    end
end

local function makeMultiAura(toolName)
    local state = { enabled = false, remote = nil, remoteSkip = 0, toolName = toolName }
    function state.start()
        state.enabled = true
        state.remote = nil
        state.remoteSkip = 0
        table.insert(activeMultiAuras, state)
        refreshMultiConn()
    end
    function state.stop()
        state.enabled = false
        for i, s in activeMultiAuras do
            if s == state then table.remove(activeMultiAuras, i) break end
        end
        state.remote = nil
        refreshMultiConn()
    end
    return state
end

