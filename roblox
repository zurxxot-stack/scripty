local killTargets = {}
local function killAuraAttack(targets, count)
    if count == 0 then return end
    local allTargets = {}
    for i = 1, count do
        local head = targets[i]:FindFirstChild("Head")
        if head then table.insert(allTargets, {targets[i], head}) end
    end
    if #allTargets == 0 then return end
    local prevTool = getEquippedTool()
    local meleeTool, alreadyEquipped = findTool(MELEE_TOOL_NAME)
    if meleeTool and not alreadyEquipped then
        if humanoid then humanoid:EquipTool(meleeTool) end
        task.wait(0.05)
    end
    pcall(function() RegisterAttack:FireServer(0) end)
    pcall(function() RegisterHit:FireServer(allTargets[1][2], allTargets) end)
    if meleeTool and not alreadyEquipped then
        if prevTool then
            if humanoid then humanoid:EquipTool(prevTool) end
        else
            if humanoid then humanoid:UnequipTools() end
        end
    end
end
