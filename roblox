                local pos = humanoidRootPart.Position
                humanoidRootPart.CFrame = CFrame.new(pos.X, 5e7, pos.Z)
                TPCooldown = true
                task.delay(10, function() TPCooldown = false end)
                Rayfield:Notify({ Title = "Low Health!", Content = "Teleported at "..math.floor(pct).."%", Duration = 3, Image = 4483362458 })
