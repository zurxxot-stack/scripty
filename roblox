local function isDeathBarrier(part)
    if not part:IsA("BasePart") then return false end
    local name = part.Name:lower()
    for _, pattern in ipairs(DEATH_BARRIER_PATTERNS) do if name:find(pattern) then return true end end
    if part.Transparency >= 0.95 and not part.CanCollide then
        for _, child in ipairs(part:GetChildren()) do
            if child:IsA("Script") or child:IsA("LocalScript") then
                local childName = child.Name:lower()
                for _, pattern in ipairs(DEATH_BARRIER_PATTERNS) do if childName:find(pattern) then return true end end
            end
        end
    end
    if part.Parent and part.Parent.Name then
        local parentName = part.Parent.Name:lower()
        for _, pattern in ipairs(DEATH_BARRIER_PATTERNS) do if parentName:find(pattern) then return true end end
    end
    if part.Material == Enum.Material.Water then return true end
    return false
end

local function disableDeathBarrier(part)
    if not part or not part.Parent then return end
    for _, data in ipairs(DeathBarrierParts) do if data.Part == part then return end end
    local originalData = { CanCollide = part.CanCollide, CanTouch = part.CanTouch, Transparency = part.Transparency, Material = part.Material, Part = part }
    table.insert(DeathBarrierParts, originalData)
    part.CanCollide = false
    part.CanTouch = false
    for _, child in ipairs(part:GetChildren()) do
        if (child:IsA("Script") or child:IsA("LocalScript")) and child.Enabled then child.Enabled = false end
    end
end

local function enableDeathBarrier(originalData)
    local part = originalData.Part
    if part and part.Parent then
        part.CanCollide = originalData.CanCollide
        part.CanTouch = originalData.CanTouch
        part.Transparency = originalData.Transparency
        for _, child in ipairs(part:GetChildren()) do
            if (child:IsA("Script") or child:IsA("LocalScript")) and not child.Enabled then child.Enabled = true end
        end
    end
end

local function scanForDeathBarriers()
    local count = 0
    for _, obj in ipairs(workspace:GetDescendants()) do
        if DeathBarrierDisabled and isDeathBarrier(obj) then disableDeathBarrier(obj) count = count + 1 end
    end
    return count
end

local function toggleDeathBarrier(value)
    DeathBarrierDisabled = value
    if DeathBarrierDisabled then
        table.clear(DeathBarrierParts)
        for _, conn in ipairs(DeathBarrierConnections) do if conn and conn.Disconnect then conn:Disconnect() end end
        table.clear(DeathBarrierConnections)
        local count = scanForDeathBarriers()
        local descendantConn = workspace.DescendantAdded:Connect(function(obj)
            if DeathBarrierDisabled then task.wait(0.1) if isDeathBarrier(obj) then disableDeathBarrier(obj) end end
        end)
        table.insert(DeathBarrierConnections, descendantConn)
        local rescanConn = task.spawn(function()
            while DeathBarrierDisabled do task.wait(5) scanForDeathBarriers() end
        end)
        table.insert(DeathBarrierConnections, {Disconnect = function() task.cancel(rescanConn) end})
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    local touchConn = part.Touched:Connect(function(hit)
                        if DeathBarrierDisabled and isDeathBarrier(hit) then if humanoid then humanoid.Health = humanoid.Health end end
                    end)
                    table.insert(DeathBarrierConnections, touchConn)
                end
            end
        end
        Rayfield:Notify({ Title = "Death Barriers Disabled", Content = "Found and disabled " .. count .. " death barriers", Duration = 3, Image = 4483362458 })
    else
        for _, originalData in ipairs(DeathBarrierParts) do enableDeathBarrier(originalData) end
        table.clear(DeathBarrierParts)
        for _, conn in ipairs(DeathBarrierConnections) do if conn and conn.Disconnect then conn:Disconnect() end end
        table.clear(DeathBarrierConnections)
        Rayfield:Notify({ Title = "Death Barriers Enabled", Content = "Death barriers restored to normal", Duration = 2, Image = 4483362458 })
    end
end

