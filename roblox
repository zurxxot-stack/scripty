-- ════════════════════════════════════════════════
-- KILL AURA
-- ════════════════════════════════════════════════
local KillAuraEnabled = false
local KillAuraThread
local KILL_AURA_RANGE = 5000
local MELEE_TOOL_NAME = "FightingStyle"

local function getEquippedTool()
    local char = Players.LocalPlayer.Character
    if not char then return nil end
    for _, v in char:GetChildren() do
        if v:IsA("Tool") then return v end
    end
end

local function findTool(name)
    local char = Players.LocalPlayer.Character
    if char then
        local t = char:FindFirstChild(name)
        if t and t:IsA("Tool") then return t, true end
    end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        local t = bp:FindFirstChild(name)
        if t and t:IsA("Tool") then return t, false end
    end
end

local function killAuraAttack(targets, count)
    if count == 0 then return end
    local allTargets = {}
    for i = 1, count do
        local head = targets[i]:FindFirstChild("Head")
        if head then table.insert(allTargets, {targets[i], head}) end
    end
    if #allTargets == 0 then return end
    local prevTool = getEquippedTool()
    local meleeTool, alreadyEquipped = findTool(MELEE_TOOL_NAME)
    if meleeTool and not alreadyEquipped then
        if humanoid then humanoid:EquipTool(meleeTool) end
        task.wait(0.05)
    end
    pcall(function() RegisterAttack:FireServer(0) end)
    pcall(function() RegisterHit:FireServer(allTargets[1][2], allTargets) end)
    if meleeTool and not alreadyEquipped then
        if prevTool then
            if humanoid then humanoid:EquipTool(prevTool) end
        else
            if humanoid then humanoid:UnequipTools() end
        end
    end
end

local killTargets = {}
local function startKillAura()
    KillAuraEnabled = true
    KillAuraThread = task.spawn(function()
        while KillAuraEnabled do
            task.wait(0.02)
            local myChar = Players.LocalPlayer.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if not myHRP then continue end
            local myPos = myHRP.Position
            local count = 0
            local ef = workspace:FindFirstChild("Enemies")
            if ef then
                for _, npc in ef:GetChildren() do
                    local h = npc:FindFirstChild("Humanoid")
                    local hrp = npc:FindFirstChild("HumanoidRootPart")
                    if h and hrp and h.Health > 0 and (hrp.Position - myPos).Magnitude <= KILL_AURA_RANGE then
                        count += 1; killTargets[count] = npc
                    end
                end
            end
            for _, p in Players:GetPlayers() do
                if p ~= player and p.Character then
                    local h = p.Character:FindFirstChild("Humanoid")
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if h and hrp and h.Health > 0 and (hrp.Position - myPos).Magnitude <= KILL_AURA_RANGE then
                        count += 1; killTargets[count] = p.Character
                    end
                end
            end
            for i = count + 1, #killTargets do killTargets[i] = nil end
            if count > 0 then killAuraAttack(killTargets, count) end
        end
    end)
end

local function stopKillAura()
    KillAuraEnabled = false
    if KillAuraThread then task.cancel(KillAuraThread) KillAuraThread = nil end
end

-- ════════════════════════════════════════════════
-- FAST ATTACK
-- ════════════════════════════════════════════════
local FastAttackEnabled, FastAttackRange = false, 2000
local FastAttackConnection

local function fastAttack(targets)
    if not FastAttackEnabled or #targets == 0 or not humanoidRootPart then return end
    pcall(function()
        local allTargets, primaryHead = {}, nil
        for _, tc in targets do
            local head = tc:FindFirstChild("Head")
            if head then
                table.insert(allTargets, {tc, head})
                primaryHead = primaryHead or head
            end
        end
        if primaryHead then
            RegisterAttack:FireServer(0)
            RegisterHit:FireServer(primaryHead, allTargets)
        end
    end)
end

local function getTargetsInRange(range)
    local myHRP = humanoidRootPart
    if not myHRP then return {} end
    local out = {}
    local ef = workspace:FindFirstChild("Enemies")
    if ef then
        for _, npc in ef:GetChildren() do
            local h = npc:FindFirstChild("Humanoid")
            local hrp = npc:FindFirstChild("HumanoidRootPart")
            if h and hrp and h.Health > 0 and (hrp.Position - myHRP.Position).Magnitude <= range then
                table.insert(out, npc)
            end
        end
    end
    for _, p in Players:GetPlayers() do
        if p ~= player and p.Character then
            local h = p.Character:FindFirstChild("Humanoid")
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if h and hrp and h.Health > 0 and (hrp.Position - myHRP.Position).Magnitude <= range then
                table.insert(out, p.Character)
            end
        end
    end
    return out
end

local function toggleFastAttack(value)
    FastAttackEnabled = value
    if value then
        if FastAttackConnection then FastAttackConnection:Disconnect() end
        FastAttackConnection = RunService.Heartbeat:Connect(function()
            local t = getTargetsInRange(FastAttackRange)
            if #t > 0 then fastAttack(t) end
        end)
    else
        if FastAttackConnection then FastAttackConnection:Disconnect() FastAttackConnection = nil end
    end
end

-- ════════════════════════════════════════════════
-- HITBOX EXTENDER
-- ════════════════════════════════════════════════
local HitboxEnabled, HitboxSize, HitboxTransparency = false, 20, 0.5
local OriginalSizes = {}

local function extendHitboxes(value)
    HitboxEnabled = value
    if value then
        local newSize = Vector3.one * HitboxSize
        for _, p in Players:GetPlayers() do
            if p ~= player and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    OriginalSizes[hrp] = OriginalSizes[hrp] or hrp.Size
                    hrp.Size = newSize hrp.Transparency = HitboxTransparency hrp.CanCollide = false
                end
            end
        end
        local ef = workspace:FindFirstChild("Enemies")
        if ef then
            for _, npc in ef:GetChildren() do
                local hrp = npc:FindFirstChild("HumanoidRootPart")
                if hrp then
                    OriginalSizes[hrp] = OriginalSizes[hrp] or hrp.Size
                    hrp.Size = newSize hrp.Transparency = HitboxTransparency hrp.CanCollide = false
                end
            end
        end
    else
        for hrp, sz in OriginalSizes do
            if hrp and hrp.Parent then hrp.Size = sz hrp.Transparency = 1 hrp.CanCollide = false end
        end
        table.clear(OriginalSizes)
    end
end

-- ════════════════════════════════════════════════
-- DEATH BARRIER DISABLER
-- ════════════════════════════════════════════════
local DeathBarrierDisabled = false
local DeathBarrierParts = {}
local DeathBarrierConnections = {}
local DEATH_PATTERNS = {"water","ocean","sea","death","kill","damage","barrier","border","bounds","lava","void","outofbounds","poisondamage","acidwater"}

local function isDeathBarrier(part)
    if not part:IsA("BasePart") then return false end
    local name = part.Name:lower()
    for _, p in DEATH_PATTERNS do if name:find(p) then return true end end
    if part.Parent then
        local pname = part.Parent.Name:lower()
        for _, p in DEATH_PATTERNS do if pname:find(p) then return true end end
    end
    return part.Material == Enum.Material.Water
end

local function disableBarrier(part)
    if not part or not part.Parent then return end
    for _, d in DeathBarrierParts do if d.Part == part then return end end
    table.insert(DeathBarrierParts, { Part = part, CanCollide = part.CanCollide, CanTouch = part.CanTouch })
    part.CanCollide = false
    part.CanTouch = false
end

local function toggleDeathBarrier(value)
    DeathBarrierDisabled = value
    if value then
        table.clear(DeathBarrierParts)
        for _, c in DeathBarrierConnections do if c and c.Disconnect then c:Disconnect() end end
        table.clear(DeathBarrierConnections)
        for _, obj in workspace:GetDescendants() do
            if isDeathBarrier(obj) then disableBarrier(obj) end
        end
        table.insert(DeathBarrierConnections, workspace.DescendantAdded:Connect(function(obj)
            if DeathBarrierDisabled then task.wait(0.1) if isDeathBarrier(obj) then disableBarrier(obj) end end
        end))
        local t = task.spawn(function()
            while DeathBarrierDisabled do task.wait(5)
                for _, obj in workspace:GetDescendants() do
                    if isDeathBarrier(obj) then disableBarrier(obj) end
                end
            end
        end)
        table.insert(DeathBarrierConnections, { Disconnect = function() task.cancel(t) end })
    else
        for _, d in DeathBarrierParts do
            if d.Part and d.Part.Parent then d.Part.CanCollide = d.CanCollide d.Part.CanTouch = d.CanTouch end
        end
        table.clear(DeathBarrierParts)
        for _, c in DeathBarrierConnections do if c and c.Disconnect then c:Disconnect() end end
        table.clear(DeathBarrierConnections)
    end
end

