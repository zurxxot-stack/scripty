-- ════════════════════════════════════════════════
-- KILL AURA
-- ════════════════════════════════════════════════
local KillAuraEnabled = false
local KillAuraThread = nil
local KILL_AURA_RANGE = 5000
local MELEE_TOOL_NAME = "FightingStyle"
local killAuraTargetsTable = {}

local function getEquippedTool()
    local char = Players.LocalPlayer.Character
    if not char then return nil end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then return v end
    end
    return nil
end

local function findTool(toolName)
    local char = Players.LocalPlayer.Character
    if char then
        local t = char:FindFirstChild(toolName)
        if t and t:IsA("Tool") then return t, true end
    end
    local bp = Players.LocalPlayer:FindFirstChild("Backpack")
    if bp then
        local t = bp:FindFirstChild(toolName)
        if t and t:IsA("Tool") then return t, false end
    end
    return nil, false
end

local function killAuraAttackTargets(targets, count)
    if not RegisterHit or not RegisterAttack then return end
    if count == 0 then return end
    local allTargets = {}
    for i = 1, count do
        local head = targets[i]:FindFirstChild("Head")
        if head then table.insert(allTargets, {targets[i], head}) end
    end
    if #allTargets == 0 then return end
    local previousTool = getEquippedTool()
    local meleeTool, alreadyEquipped = findTool(MELEE_TOOL_NAME)
    if meleeTool and not alreadyEquipped then
        if humanoid then humanoid:EquipTool(meleeTool) end
        task.wait(0.05)
    end
    pcall(function() RegisterAttack:FireServer(0) end)
    pcall(function() RegisterHit:FireServer(allTargets[1][2], allTargets) end)
    if meleeTool and not alreadyEquipped then
        if previousTool then
            if humanoid then humanoid:EquipTool(previousTool) end
        else
            if humanoid then humanoid:UnequipTools() end
        end
    end
end

local function startKillAura()
    KillAuraEnabled = true
    KillAuraThread = task.spawn(function()
        while KillAuraEnabled do
            task.wait(0.02)
            local myChar = Players.LocalPlayer.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if not myHRP then continue end
            local myPos = myHRP.Position
            local count = 0
            local ef = workspace:FindFirstChild("Enemies")
            if ef then
                for _, npc in pairs(ef:GetChildren()) do
                    local npcHum = npc:FindFirstChild("Humanoid")
                    local hrp = npc:FindFirstChild("HumanoidRootPart")
                    if npcHum and hrp and npcHum.Health > 0 and
                       (hrp.Position - myPos).Magnitude <= KILL_AURA_RANGE then
                        count += 1; killAuraTargetsTable[count] = npc
                    end
                end
            end
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Players.LocalPlayer and p.Character then
                    local pHum = p.Character:FindFirstChild("Humanoid")
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if pHum and hrp and pHum.Health > 0 and
                       (hrp.Position - myPos).Magnitude <= KILL_AURA_RANGE then
                        count += 1; killAuraTargetsTable[count] = p.Character
                    end
                end
            end
            for i = count + 1, #killAuraTargetsTable do killAuraTargetsTable[i] = nil end
            if count > 0 then killAuraAttackTargets(killAuraTargetsTable, count) end
        end
    end)
end

local function stopKillAura()
    KillAuraEnabled = false
    if KillAuraThread then task.cancel(KillAuraThread) KillAuraThread = nil end
end

local function updatePlayerCache()
    local currentTime = tick()
    if currentTime - lastPlayerCacheUpdate < cacheUpdateInterval then return cachedPlayers end
    table.clear(cachedPlayers)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then table.insert(cachedPlayers, p) end
    end
    lastPlayerCacheUpdate = currentTime
    return cachedPlayers
end

local function updateNPCCache()
    local currentTime = tick()
    if currentTime - lastNPCCacheUpdate < cacheUpdateInterval then return cachedNPCs end
    table.clear(cachedNPCs)
    if enemiesFolder then
        for _, npc in ipairs(enemiesFolder:GetChildren()) do
            local npcHumanoid = npc:FindFirstChild("Humanoid")
            if npcHumanoid and npcHumanoid.Health > 0 then table.insert(cachedNPCs, npc) end
        end
    end
    lastNPCCacheUpdate = currentTime
    return cachedNPCs
