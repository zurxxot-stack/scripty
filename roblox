local function onCharacterAdded(char)
    character = char
    humanoidRootPart = char:WaitForChild("HumanoidRootPart")
    humanoid = char:WaitForChild("Humanoid")
    isTeleportedToSky, originalPosition = false, nil

    -- Orbit and instantTP are self-healing (read live HRP each frame), nothing to restart.
    -- Clean up orbit only if the target player actually left.
    if orbiting and (not selectedPlayer or not selectedPlayer.Parent) then
        orbiting = false selectedPlayer = nil currentTarget = nil
        if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
    end

    -- Restart instantTP after respawn if it was active
    if instantTPEnabled and tpSelectedName then
        if instantTPConnection then instantTPConnection:Disconnect() instantTPConnection = nil end
        instantTPEnabled = false
        startInstantTP()
    end

    if KillAuraEnabled then stopKillAura() task.wait(0.2) startKillAura() end
    if flyEnabled then stopFly() task.wait(0.5) startFly() end

    -- Restart all auras
    for _, aura in Auras do
        if aura.single.enabled then aura.single.stop() aura.single.enabled = true aura.single.start() end
        if aura.multi.enabled  then aura.multi.stop()  aura.multi.enabled  = true aura.multi.start()  end
    end

    camera.CameraSubject = humanoid
end

