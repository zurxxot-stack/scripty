-- KEYBINDS
-- ════════════════════════════════════════════════
local holdingH = false

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.N then toggleTeleportToSky() end
    if input.KeyCode == Enum.KeyCode.H and not holdingH then
        holdingH = true
        task.spawn(function()
            while holdingH do
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if hrp then hrp.CFrame = CFrame.new(0, 100000000000000, 0) end
                task.wait(0.05)
            end
        end)
        Rayfield:Notify({ Title = "Hold Teleport: ON", Content = "Holding H — spamming teleport", Duration = 2, Image = 4483362458 })
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.H then
        holdingH = false
        Rayfield:Notify({ Title = "Hold Teleport: OFF", Content = "Released H", Duration = 1, Image = 4483362458 })
    end
end)

