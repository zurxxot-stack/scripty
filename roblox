-- ════════════════════════════════════════════════
-- SHARED MULTI-DIR AURA DIRECTIONS
-- ════════════════════════════════════════════════
local allDirs = {}
do
    local count  = 16
    local scales = {1, 100, 9999}
    for _, scale in ipairs(scales) do
        for i = 0, count - 1 do
            local yaw   = (i / count) * math.pi * 2
            local pitch = math.sin((i / count) * math.pi) * math.pi / 2
            table.insert(allDirs, vector.create(
                math.cos(pitch) * math.cos(yaw) * scale,
                math.sin(pitch) * scale,
                math.cos(pitch) * math.sin(yaw) * scale
            ))
        end
    end
end
local dirCount = #allDirs
local EXTRA_DIR = vector.create(-0.9945698976516724, 0, 0.10407081246376038)

-- ════════════════════════════════════════════════
-- T-REX MULTI-DIR AURA
-- ════════════════════════════════════════════════
local TRexMultiAuraEnabled = false
local TRexMultiAuraConn = nil
local tRexDirIndex = 0
local tRexFrameSkip = 0
local cachedTRexRemote = nil
local tRexRemoteCheckSkip = 0

local function findTRexRemote()
    local function search(parent)
        if not parent then return nil end
        local tool = parent:FindFirstChild("T-Rex-T-Rex")
        return tool and tool:FindFirstChild("LeftClickRemote")
    end
    return search(Players.LocalPlayer.Character) or search(Players.LocalPlayer:FindFirstChild("Backpack"))
end

local function startTRexMultiAura()
    if TRexMultiAuraConn then TRexMultiAuraConn:Disconnect() TRexMultiAuraConn = nil end
    tRexFrameSkip = 0
    tRexRemoteCheckSkip = 0
    cachedTRexRemote = nil
    TRexMultiAuraConn = RunService.Heartbeat:Connect(function()
        if not TRexMultiAuraEnabled then TRexMultiAuraConn:Disconnect() TRexMultiAuraConn = nil return end
        tRexFrameSkip += 1
        if tRexFrameSkip % 3 ~= 0 then return end
        tRexRemoteCheckSkip += 1
        if tRexRemoteCheckSkip >= 120 or not cachedTRexRemote then
            tRexRemoteCheckSkip = 0
            cachedTRexRemote = findTRexRemote()
        end
        local remote = cachedTRexRemote
        if not remote then return end
        pcall(function()
            for i = 1, 4 do
                tRexDirIndex = (tRexDirIndex % dirCount) + 1
                remote:FireServer(allDirs[tRexDirIndex], 1)
            end
            for i = 1, 2 do
                remote:FireServer(EXTRA_DIR, 2)
            end
        end)
    end)
end

local function stopTRexMultiAura()
    TRexMultiAuraEnabled = false
    if TRexMultiAuraConn then TRexMultiAuraConn:Disconnect() TRexMultiAuraConn = nil end
    cachedTRexRemote = nil
end

