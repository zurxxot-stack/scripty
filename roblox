-- ════════════════════════════════════════════════
-- ORBIT & INSTANT TP
-- ════════════════════════════════════════════════
local orbiting = false
local orbitSpeed, orbitRadius, xOffset, yOffset, xScale, orbitAngle = 1, 3, 0, 0, 3, 0
local orbitConnection
local selectedPlayer, currentTarget
local orbitSelectedName, spectateSelectedName, tpSelectedName

-- ════════════════════════════════════════════════
-- PREDICTION ENGINE
-- Weighted least-squares over rolling 8-sample window.
-- Zero per-frame allocations. Teleport detection, jerk guard,
-- confidence-weighted kinematic extrapolation.
-- ════════════════════════════════════════════════
local orbitPredictionEnabled = false
local orbitPredictionStrength = 0.2
local orbitAutoPrediction = true

local PRED_WINDOW   = 8
local PRED_TP_DIST  = 80     -- stud jump → flush
local PRED_JERK_MAX = 2000   -- studs/s³ → confidence penalty
local PRED_DECAY    = 0.75   -- geometric sample weight

-- Pre-allocated ring buffer: reuse slot tables, never alloc per-frame
local predBuf = {}
for i = 1, PRED_WINDOW do predBuf[i] = { px=0, py=0, pz=0, t=0 } end
local predBufN    = 0   -- valid entries
local predBufHead = 0   -- newest slot index (1-based)

-- State
local kPx,kPy,kPz   = 0,0,0
local kVx,kVy,kVz   = 0,0,0
local kAx,kAy,kAz   = 0,0,0
local kReady  = false
local predConf = 0

local function predReset()
    predBufN, predBufHead = 0, 0
    kPx,kPy,kPz = 0,0,0
    kVx,kVy,kVz = 0,0,0
    kAx,kAy,kAz = 0,0,0
    kReady, predConf = false, 0
end

local function predFitWindow()
    local n = predBufN
    if n < 2 then return end

    -- Accumulate weighted normal-equation sums in one pass.
    -- Model: pos(s) = a0 + a1*s + a2*s²  where s = t - t_newest (≤0)
    -- We only need a1 (velocity) and a2 (½ accel), so we solve the 3×3 system.
    local head = predBufHead
    local tn   = predBuf[head].t

    local sw0,sw1,sw2,sw3,sw4 = 0,0,0,0,0
    local srpx,srpy,srpz = 0,0,0       -- Σw·p
    local srspx,srspy,srspz = 0,0,0    -- Σw·s·p
    local srs2px,srs2py,srs2pz = 0,0,0 -- Σw·s²·p

    local w = 1.0  -- starts at DECAY^0 = 1 for newest, multiplied each step
    for i = 0, n-1 do
        local slot = predBuf[((head - 1 - i) % PRED_WINDOW) + 1]
        local s  = slot.t - tn   -- ≤ 0
        local s2 = s * s
        sw0 += w;       sw1 += w*s;  sw2 += w*s2
        sw3 += w*s2*s;  sw4 += w*s2*s2
        local wpx,wpy,wpz = w*slot.px, w*slot.py, w*slot.pz
        srpx  += wpx;      srpy  += wpy;      srpz  += wpz
        srspx += wpx*s;    srspy += wpy*s;    srspz += wpz*s   -- w*s*p = (w*p)*s
        srs2px+= wpx*s2;   srs2py+= wpy*s2;  srs2pz+= wpz*s2
        w *= PRED_DECAY
    end

    -- Solve 3×3 via Cramer. Matrix M is the same for all axes → compute once.
    -- M = [[sw0,sw1,sw2],[sw1,sw2,sw3],[sw2,sw3,sw4]]
    local c00 = sw2*sw4 - sw3*sw3
    local c01 = sw3*sw2 - sw1*sw4   -- = -(sw1*sw4 - sw3*sw2)
    local c02 = sw1*sw3 - sw2*sw2
    local det = sw0*c00 + sw1*c01 + sw2*c02
    if math.abs(det) < 1e-9 then return end
    local inv = 1 / det

    -- Cofactors for rows 1 and 2 (velocity and accel columns)
    local c10 = sw3*sw2 - sw1*sw4   -- same as c01 by symmetry... let's be explicit
    local c11 = sw0*sw4 - sw2*sw2
    local c12 = sw1*sw2 - sw0*sw3
    local c20 = sw1*sw3 - sw2*sw2
    local c21 = sw2*sw1 - sw0*sw3   -- = -(sw0*sw3 - sw1*sw2)
    local c22 = sw0*sw2 - sw1*sw1

    local function solveVelAccel(b0, b1, b2)
        local v = (b0*c10 + b1*c11 + b2*c12) * inv
        local a = (b0*c20 + b1*c21 + b2*c22) * inv
        return v, a * 2   -- a2 coeff × 2 = acceleration
    end

    local fvx,fax = solveVelAccel(srpx, srspx, srs2px)
    local fvy,fay = solveVelAccel(srpy, srspy, srs2py)
    local fvz,faz = solveVelAccel(srpz, srspz, srs2pz)

    -- Jerk guard
    local jdx,jdy,jdz = fax-kAx, fay-kAy, faz-kAz
    local dtSample = math.max(n >= 2 and (tn - predBuf[((head-2)%PRED_WINDOW)+1].t) or 1, 1e-4)
    local jerk = math.sqrt(jdx*jdx + jdy*jdy + jdz*jdz) / dtSample
    if jerk > PRED_JERK_MAX then predConf = math.max(predConf - 0.4, 0) end

    -- Blend into state
    local trust = math.clamp(n / PRED_WINDOW, 0.2, 1.0)
    local tv, ta = trust * 0.6, trust * 0.3
    kVx = kVx + (fvx - kVx) * tv;  kVy = kVy + (fvy - kVy) * tv;  kVz = kVz + (fvz - kVz) * tv
    kAx = kAx + (fax - kAx) * ta;  kAy = kAy + (fay - kAy) * ta;  kAz = kAz + (faz - kAz) * ta
    kPx = predBuf[head].px;  kPy = predBuf[head].py;  kPz = predBuf[head].pz
    kReady = true
    predConf = math.min(predConf + 0.15, 1.0)
end

local function predUpdate(pos)
    local now = tick()
    local px,py,pz = pos.X, pos.Y, pos.Z

    -- Teleport detection against newest slot
    if predBufN > 0 then
        local s = predBuf[predBufHead]
        local dx,dy,dz = px-s.px, py-s.py, pz-s.pz
        if dx*dx + dy*dy + dz*dz > PRED_TP_DIST*PRED_TP_DIST then predReset() end
    end

    -- Overwrite next ring slot in-place (zero alloc)
    predBufHead = (predBufHead % PRED_WINDOW) + 1
    local slot = predBuf[predBufHead]
    slot.px, slot.py, slot.pz, slot.t = px, py, pz, now
    predBufN = math.min(predBufN + 1, PRED_WINDOW)

    predFitWindow()
end

local function predExtrapolate(ahead)
    if not kReady then return Vector3.new(kPx,kPy,kPz) end
    local c  = predConf
    local ac = math.max(1 - ahead * 1.2, 0) * c
    local h2 = 0.5 * ahead * ahead
    return Vector3.new(
        kPx + kVx*ahead*c + kAx*h2*ac,
        kPy + kVy*ahead*c + kAy*h2*ac,
        kPz + kVz*ahead*c + kAz*h2*ac
    )
end

local function predLookAhead()
    if not orbitAutoPrediction then return orbitPredictionStrength end
    local spd = math.sqrt(kVx*kVx + kVy*kVy + kVz*kVz)
    local acc = math.sqrt(kAx*kAx + kAy*kAy + kAz*kAz)
    return math.clamp((math.clamp(spd/300,0,1) + math.clamp(acc/400,0,0.4)) * predConf, 0, 1.4)
end

local instantTPEnabled = false
local instantTPConnection

local autoResetEnabled = false
local autoResetThread

local function getPlayerByName(name)
    return name and Players:FindFirstChild(name)
end

local function startOrbit()
    local tp = getPlayerByName(orbitSelectedName)
    if not tp or not tp.Character or not tp.Character:FindFirstChild("HumanoidRootPart") then
        Rayfield:Notify({ Title = "No Target", Content = "Select a player first", Duration = 2, Image = 4483362458 })
        return false
    end
    if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
    orbiting = true
    selectedPlayer = tp
    currentTarget = tp.Character.HumanoidRootPart
    orbitAngle = 0
    Rayfield:Notify({ Title = "Orbiting: ON", Content = "Orbiting "..tp.Name, Duration = 2, Image = 4483362458 })

    orbitConnection = RunService.Heartbeat:Connect(function(dt)
        local myChar = Players.LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        character, humanoidRootPart = myChar, myHRP

        -- Handle target respawn: re-grab HRP if it went nil
        if not currentTarget or not currentTarget.Parent then
            if selectedPlayer and selectedPlayer.Parent then
                local newChar = selectedPlayer.Character
                currentTarget = newChar and newChar:FindFirstChild("HumanoidRootPart")
                if not currentTarget then return end
            else
                orbiting = false selectedPlayer = nil currentTarget = nil
                orbitConnection:Disconnect() orbitConnection = nil
                Rayfield:Notify({ Title = "Orbit Stopped", Content = "Target left", Duration = 2, Image = 4483362458 })
                return
            end
        end

        local targetHum = currentTarget.Parent:FindFirstChild("Humanoid")
        if not targetHum or targetHum.Health <= 0 then return end -- target dead, wait for respawn

        orbitAngle += orbitSpeed * dt

        local targetPos = currentTarget.Position
        if orbitPredictionEnabled then
            predUpdate(targetPos)
            if kReady then
                targetPos = predExtrapolate(predLookAhead())
            end
        else
            predReset()
        end

        local offset = Vector3.new(math.cos(orbitAngle) * orbitRadius * xScale + xOffset, yOffset, math.sin(orbitAngle) * orbitRadius)
        myHRP.CFrame = CFrame.lookAt(targetPos + offset, targetPos)
        camera.CameraSubject = targetHum
    end)
    return true
end

local function stopOrbit()
    orbiting = false selectedPlayer = nil currentTarget = nil orbitAngle = 0
    if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
    if character and character:FindFirstChild("Humanoid") then camera.CameraSubject = character.Humanoid end
    Rayfield:Notify({ Title = "Orbiting: OFF", Content = "Stopped", Duration = 2, Image = 4483362458 })
end

local function spectatePlayer()
    local tp = getPlayerByName(spectateSelectedName)
    if not tp or not tp.Character then
        Rayfield:Notify({ Title = "No Target", Content = "Select a player first", Duration = 2, Image = 4483362458 })
        return
    end
    local hum = tp.Character:FindFirstChild("Humanoid")
    if hum then
        camera.CameraSubject = hum
        Rayfield:Notify({ Title = "Spectating", Content = tp.Name, Duration = 2, Image = 4483362458 })
    end
end

local function unspectate()
    if character and character:FindFirstChild("Humanoid") then
        camera.CameraSubject = character.Humanoid
        Rayfield:Notify({ Title = "Unspectated", Content = "Camera restored", Duration = 2, Image = 4483362458 })
    end
end

local function startInstantTP()
    local tp = getPlayerByName(tpSelectedName)
    if not tp or not tp.Character then
        Rayfield:Notify({ Title = "No Target", Content = "Select a player first", Duration = 2, Image = 4483362458 })
        return false
    end
    if instantTPConnection then instantTPConnection:Disconnect() instantTPConnection = nil end
    instantTPEnabled = true
    Rayfield:Notify({ Title = "Instant TP: ON", Content = "Following "..tp.Name, Duration = 2, Image = 4483362458 })

    instantTPConnection = RunService.Heartbeat:Connect(function()
        if not instantTPEnabled then instantTPConnection:Disconnect() instantTPConnection = nil return end
        local target = getPlayerByName(tpSelectedName)
        if not target or not target.Parent then
            instantTPEnabled = false
            instantTPConnection:Disconnect() instantTPConnection = nil
            if Rayfield.Flags["InstantTPToggle"] then Rayfield.Flags["InstantTPToggle"]:Set(false) end
            Rayfield:Notify({ Title = "Instant TP: OFF", Content = "Target left", Duration = 2, Image = 4483362458 })
            return
        end
        if not target.Character then return end
        local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if not tHRP then return end
        local myChar = Players.LocalPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        humanoidRootPart = myHRP

        local tpPos = tHRP.Position
        if orbitPredictionEnabled and kReady then
            tpPos = predExtrapolate(predLookAhead())
        end
        myHRP.CFrame = CFrame.new(tpPos + Vector3.new(0, 3, 0))
    end)
    return true
end

local function stopInstantTP()
    instantTPEnabled = false
    if instantTPConnection then instantTPConnection:Disconnect() instantTPConnection = nil end
    Rayfield:Notify({ Title = "Instant TP: OFF", Content = "Stopped", Duration = 2, Image = 4483362458 })
end

