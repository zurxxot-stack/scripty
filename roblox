    Rayfield:Notify({ Title = "Orbiting: ON", Content = "Orbiting "..tp.Name, Duration = 2, Image = 4483362458 })
    orbitConnection = RunService.Heartbeat:Connect(function(dt)
        local myChar = player.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        character, humanoidRootPart = myChar, myHRP
        if not currentTarget or not currentTarget.Parent then
            if selectedPlayer and selectedPlayer.Parent then
                local newChar = selectedPlayer.Character
                currentTarget = newChar and newChar:FindFirstChild("HumanoidRootPart")
                if not currentTarget then return end
            else
                orbiting = false selectedPlayer = nil currentTarget = nil
                orbitConnection:Disconnect() orbitConnection = nil
                Rayfield:Notify({ Title = "Orbit Stopped", Content = "Target left", Duration = 2, Image = 4483362458 })
                return
            end
        end
        local targetHum = currentTarget.Parent:FindFirstChild("Humanoid")
        if not targetHum or targetHum.Health <= 0 then return end
        orbitAngle += orbitSpeed * dt
        local targetPos = currentTarget.Position
        if orbitPredictionEnabled then
            predUpdate(targetPos)
            if kReady then targetPos = predExtrapolate(predLookAhead()) end
        else
            predReset()
        end
        local offset = Vector3.new(math.cos(orbitAngle) * orbitRadius * xScale + xOffset, yOffset, math.sin(orbitAngle) * orbitRadius)
        myHRP.CFrame = CFrame.lookAt(targetPos + offset, targetPos)
        camera.CameraSubject = targetHum
    end)
    return true
end
