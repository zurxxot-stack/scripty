local function startOrbit()
    local targetPlayer = getPlayerByName(orbitSelectedName)
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        Rayfield:Notify({ Title = "No Target", Content = "Select a player from the dropdown first", Duration = 2, Image = 4483362458 })
        return false
    end
    if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
    orbiting = true
    selectedPlayer = targetPlayer
    currentTarget = targetPlayer.Character.HumanoidRootPart
    orbitAngle = 0
    Rayfield:Notify({ Title = "Orbiting: ON", Content = "Orbiting " .. targetPlayer.Name, Duration = 2, Image = 4483362458 })
    orbitConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not character or not humanoidRootPart or not humanoidRootPart.Parent then
            orbiting = false if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end return
        end
        if not currentTarget or not currentTarget.Parent or not selectedPlayer.Parent then
            orbiting = false selectedPlayer = nil currentTarget = nil
            if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
            if character:FindFirstChild("Humanoid") then camera.CameraSubject = character.Humanoid end
            Rayfield:Notify({ Title = "Orbit Stopped", Content = "Target left or died", Duration = 2, Image = 4483362458 })
            return
        end
        local targetHumanoid = currentTarget.Parent:FindFirstChild("Humanoid")
        if not targetHumanoid or targetHumanoid.Health <= 0 then
            orbiting = false selectedPlayer = nil currentTarget = nil
            if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
            if character:FindFirstChild("Humanoid") then camera.CameraSubject = character.Humanoid end
            Rayfield:Notify({ Title = "Orbit Stopped", Content = "Target died", Duration = 2, Image = 4483362458 })
            return
        end
        orbitAngle = orbitAngle + (orbitSpeed * deltaTime)

        -- Prediction: estimate target's future position based on velocity
        local targetPos = currentTarget.Position
        if orbitPredictionEnabled then
            if lastTargetPosition then
                -- Smooth the velocity estimate with lerp to avoid jitter
                local rawVelocity = (targetPos - lastTargetPosition) / deltaTime
                predictedVelocity = predictedVelocity:Lerp(rawVelocity, 0.3)
            end
            lastTargetPosition = targetPos
            targetPos = targetPos + predictedVelocity * orbitPredictionStrength
        else
            lastTargetPosition = nil
            predictedVelocity = Vector3.new(0, 0, 0)
        end

        local offset = Vector3.new(math.cos(orbitAngle) * orbitRadius * xScale + xOffset, yOffset, math.sin(orbitAngle) * orbitRadius)
        humanoidRootPart.CFrame = CFrame.lookAt(targetPos + offset, targetPos)
        camera.CameraSubject = targetHumanoid
    end)
    return true
end

local function stopOrbit()
    orbiting = false selectedPlayer = nil currentTarget = nil orbitAngle = 0
    if orbitConnection then orbitConnection:Disconnect() orbitConnection = nil end
    if character and character:FindFirstChild("Humanoid") then camera.CameraSubject = character.Humanoid end
    Rayfield:Notify({ Title = "Orbiting: OFF", Content = "No longer orbiting", Duration = 2, Image = 4483362458 })
end

